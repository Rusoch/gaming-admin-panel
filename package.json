{
	"name": "gaming-admin-panel",
	"description": "GamingAdminPanel — admin UI for Leaderboard, Raffle, and Wheel gaming features.",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n api,ui -c cyan,magenta \"npm run server\" \"vite\"",
		"start": "npm run dev",
		"vite": "vite",
		"server": "json-server -p 3000 --watch db.json",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@hookform/resolvers": "^5.2.2",
		"@mui/icons-material": "^5.16.14",
		"@mui/material": "^5.16.14",
		"@tanstack/react-query": "^5.95.2",
		"axios": "^1.13.6",
		"json-server": "^1.0.0-beta.15",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.72.0",
		"react-router-dom": "^6.28.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^24.12.0",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.1"
	}
}
